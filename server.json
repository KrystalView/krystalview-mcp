{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.KrystalView/krystalview",
  "title": "KrystalView Analytics",
  "description": "Read-only MCP access to sessions, funnels, campaigns, errors, live visitors, and anomalies.",
  "repository": {
    "url": "https://github.com/KrystalView/krystalview-mcp",
    "source": "github"
  },
  "version": "0.1.6",
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "krystalview-mcp",
      "version": "0.1.6",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "KRYSTALVIEW_API_KEY",
          "description": "Your KrystalView API key (generate in console under Settings > API Keys)",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "KRYSTALVIEW_BASE_URL",
          "description": "API base URL (default: https://krystalview.com/api)",
          "isRequired": false,
          "format": "string",
          "isSecret": false
        }
      ]
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://krystalview.com/mcp"
    }
  ],
  "websiteUrl": "https://krystalview.com"
}
